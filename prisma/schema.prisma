generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

enum Role {
  OPS
  VALIDATOR
  TL
  ADMIN
}

enum CandidateStatus {
  PENDING
  OPS_VERIFIED
  VALIDATED
  REJECTED
  READY
}

enum DocumentType {
  PHOTO
  QUALIFICATION
  ID_PROOF
  ID_PROOF_FRONT
  ID_PROOF_BACK
  SIGNATURE
}

enum IDType {
  PAN
  AADHAAR
  DL
  PASSPORT
}

enum DocumentStatus {
  PENDING
  VERIFIED
  REJECTED
}

model User {
  id    String @id @default(cuid())
  name  String?
  email String @unique
  role  Role   @default(OPS)
}

enum CurrentStep {
  STARTED
  PERSONAL_INFO_DONE
  UPLOADING_DOCS
  COMPLETED
}

model Candidate {
  id           String          @id @default(cuid())
  token        String          @unique @default(uuid())
  name         String?
  employer     String?
  mobileNumber String?
  employeeId   String?
  idType       IDType?
  idNumber     String?
  status       CandidateStatus @default(PENDING)
  currentStep  CurrentStep     @default(STARTED)
  lastActiveAt DateTime        @default(now())
  documents    Document[]
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
}

model Document {
  id              String         @id @default(cuid())
  candidateId     String
  candidate       Candidate      @relation(fields: [candidateId], references: [id])
  type            DocumentType
  fileUrl         String
  sizeKB          Int
  status          DocumentStatus @default(PENDING)
  rejectionReason String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

