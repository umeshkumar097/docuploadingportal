generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

enum Role {
  OPS
  VALIDATOR
  TL
  ADMIN
  VENDOR
  SUPERADMIN
}

enum CandidateStatus {
  PENDING
  OPS_VERIFIED
  VALIDATED
  REJECTED
  READY
}

enum DocumentType {
  PHOTO
  QUALIFICATION
  ID_PROOF
  ID_PROOF_FRONT
  ID_PROOF_BACK
  SIGNATURE
  DRA_CERTIFICATE
}

enum IDType {
  PAN
  AADHAAR
  DL
  PASSPORT
}

enum DocumentStatus {
  PENDING
  VERIFIED
  REJECTED
}

model Client {
  id        String      @id @default(cuid())
  name      String      @unique
  slug      String      @unique
  candidates Candidate[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

model User {
  id    String @id @default(cuid())
  name       String?
  email      String @unique
  role       Role   @default(OPS)
  vendorName String?
  password   String?
}

enum CurrentStep {
  STARTED
  PERSONAL_INFO_DONE
  UPLOADING_DOCS
  COMPLETED
}

model Candidate {
  id           String          @id @default(cuid())
  token        String          @unique @default(uuid())
  name             String?
  employer         String?
  phase            String?         @default("Phase 1")
  clientId         String?
  client           Client?         @relation(fields: [clientId], references: [id])
  residentialState String?
  city             String?
  pincode          String?
  mobileNumber     String?
  employeeId       String?
  idType       IDType?
  idNumber     String?
  isDraCertified Boolean         @default(false)
  status       CandidateStatus @default(PENDING)
  currentStep  CurrentStep     @default(STARTED)
  lastActiveAt DateTime        @default(now())
  documents    Document[]
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
}

model Document {
  id              String         @id @default(cuid())
  candidateId     String
  candidate       Candidate      @relation(fields: [candidateId], references: [id])
  type            DocumentType
  fileUrl         String
  sizeKB          Int
  status          DocumentStatus @default(PENDING)
  rejectionReason String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model MasterEmployee {
  id                    String   @id @default(cuid())
  employeeId            String   @unique
  employeeName          String?
  state                 String?
  reportingManagerId    String?
  reportingManagerName  String?
  reportingManagerGroup String?
  skipLevelManagerId    String?
  skipLevelManagerName  String?
  activeStatus          String?
  email                 String?
  officeMobileNo        String?
  personalMobileNo      String?
  whatsappNo            String?
  vendor                String?
  phase                 String?   @default("Phase 1")
  region2               String?
  location2             String?
  city                  String?
  pincode               String?
  draBatch              String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model AddressRecord {
  id              String   @id @default(cuid())
  employeeId      String
  phoneNumber     String
  name            String
  companyAgency   String
  fullAddress     String
  city            String
  state           String
  pincode         String
  bookLanguage    String   @default("English")
  createdAt       DateTime @default(now())
}

model SystemSetting {
  id    String @id @default(cuid())
  key   String @unique // e.g. "ADD_FORM_ENABLED"
  value String // "true" or "false"
}

